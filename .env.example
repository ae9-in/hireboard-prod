# HireWave Environment Variables Template
# Copy this file to .env.local and populate with secrets.

# MongoDB Connection String (e.g. mongodb://127.0.0.1:27017/hirewave or Atlas URI)
MONGODB_URI=

# Secret key for signing JWT Access Tokens (use a strong random hash)
JWT_SECRET=

# Secret key for signing JWT Refresh Tokens (use a strong random hash)
JWT_REFRESH_SECRET=
